<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="financial_expense_view_form" model="ir.ui.view">
            <field name="name">financial.Expense.View.Form</field>
            <field name="model">financial.expense</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="to_account1" string="To Account 1"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'draft'"
                                groups="add_menu_exp_account.group_financial_creator,add_menu_exp_account.group_financial_expense_admin"/>

                        <button name="to_chief_acc" string="To Chief Accountant"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'account1'"
                                groups="add_menu_exp_account.group_financial_account1,add_menu_exp_account.group_financial_expense_admin"/>

                        <button name="to_cfo" string="To CFO"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'chief_acc'"
                                groups="add_menu_exp_account.group_financial_chief_acc,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="to_upload_bank" string="To Cash Management"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'cfo'"
                                groups="add_menu_exp_account.group_financial_cfo,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="to_approve" string="To Cash Management"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'upload_bank'"
                                groups="add_menu_exp_account.group_financial_upload_bank,add_menu_exp_account.group_financial_expense_admin"/>

                        <button name="to_account2" string="To Account 2"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'approve'"
                                groups="add_menu_exp_account.group_financial_approve,add_menu_exp_account.group_financial_expense_admin"/>
                        <!--                             Refuse                                -->
                        <button name="refuse_account1" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'account1'"
                                groups="add_menu_exp_account.group_financial_account1,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="refuse_chief_acc" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'chief_acc'"
                                groups="add_menu_exp_account.group_financial_chief_acc,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="refuse_cfo" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'cfo'"
                                groups="add_menu_exp_account.group_financial_cfo,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="refuse_upload_bank" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'upload_bank'"
                                groups="add_menu_exp_account.group_financial_upload_bank,add_menu_exp_account.group_financial_expense_admin"/>
                        <button name="refuse_approve" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'approve'"
                                groups="add_menu_exp_account.group_financial_approve,add_menu_exp_account.group_financial_expense_admin"/>


                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="seq" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="expense_date"
                                       readonly="state != 'draft'"/>
                                <field name="user_id" invisible="0" readonly="1"/>
                                <field name="department_id" invisible="0" readonly="1"/>
                            </group>
                            <group>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
                            </group>
                            <group>
                                <field name="name" readonly="state != 'draft'"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Expenses">
                                <field name="expenses_ids"
                                       readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="product_ids" options="{'no_create': True}"/>
                                        <field name="name" optional="show"/>
                                        <field name="vendor_id" optional="show"/>
                                        <field name="attachment_ids" widget="many2many_binary" optional="show"
                                               readonly="parent.state not in ['draft', 'financial_manager']"/>
                                        <field name="quantity" optional="show"/>
                                        <field name="price_unit" optional="show"/>
                                        <field name="tax_ids" widget="many2many_tags" optional="show"/>
                                        <field name="vat_value" optional="show"/>
                                        <field name="price_subtotal" optional="show"/>
                                    </list>
                                </field>
                                <group>
                                    <group>

                                    </group>
                                    <group class="oe_subtotal_footer oe_right" colspan="2">
                                        <field name="amount_taxed" widget="monetary" readonly="1"/>
                                        <field name="tax" widget="monetary" readonly="1"/>
                                        <field name="total" widget="monetary" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Assign to Users" invisible="1">
                                <group>
                                    <group>
                                        <field name="account1" options="{'no_create': True}"/>
                                        <field name="chief_acc" options="{'no_create': True}"/>
                                        <field name="cfo" options="{'no_create': True}"/>
                                    </group>
                                    <group>
                                        <field name="upload_bank" options="{'no_create': True}"/>
                                        <field name="approve" options="{'no_create': True}"/>
                                        <field name="account2" options="{'no_create': True}"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="financial_expense_view_tree" model="ir.ui.view">
            <field name="name">Financial.Expense.View.Tree</field>
            <field name="model">financial.expense</field>
            <field name="arch" type="xml">
                <list string="">
                    <field name="seq" readonly="1"/>
                    <field name="user_id"/>
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="expense_date"/>
                    <field name="total" sum="Total"/>
                    <field name="amount_taxed" sum="Un Taxed"/>
                    <field name="tax" sum="Tax"/>
                </list>
            </field>
        </record>


        <record id="financial_expense_view_action" model="ir.actions.act_window">
            <field name="name">Financial Expenses</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">financial.expense</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
            </field>
        </record>


        <menuitem id="financial_expense_view_menu" name="Financial Expenses" parent="add_menu_exp_account.Expense_view_menu_ID_categ"
                  action="financial_expense_view_action" sequence="20" groups="add_menu_exp_account.group_financial_expense_user"/>


    </data>
</odoo>