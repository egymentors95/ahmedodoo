<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="id_expenses_report" model="ir.actions.report">
            <field name="name">Expenses</field>
            <field name="model">expense.expense</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">add_menu_exp_account.id_expenses_report_template</field>
            <field name="report_file">add_menu_exp_account.id_expenses_report_template</field>
            <field name="binding_model_id" ref="model_expense_expense"/>
        </record>
        <template id="id_expenses_report_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="add_menu_exp_account.custom_standard_external_layout">
                        <t t-set="company" t-value="res_company"/>
                        <table width="50%" style="border-collapse: collapse;">
                            <tr>
                                <td style="border: 2px solid #1090C2;">
                                    Date :
                                    <span t-field="o.expense_date"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 2px solid #1090C2;">
                                    Ref :
                                    <span t-field="o.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 2px solid #1090C2;">
                                    Journal :
                                    <span t-field="o.journal_id"/>
                                </td>
                            </tr>
                        </table>
                        <br></br>
                        <br></br>
                        <table width="100%">
                            <thead>
                                <tr>
                                    <th name="th_source"
                                        style="border: 2px solid #1090C2;; background-color: #1090C2;; color: white;"
                                        class="text-center">
                                        <span>Description</span>
                                    </th>
                                    <th name="th_quantity"
                                        style="border: 2px solid #1090C2;; background-color: #1090C2;; color: white;"
                                        class="text-center">
                                        <span>Quantity</span>
                                    </th>
                                    <th name="th_priceunit"
                                        t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"
                                        style="border: 2px solid #1090C2;; background-color: #1090C2;; color: white;">
                                        <span>Price</span>
                                    </th>
                                    <th name="th_purchase_unit"
                                        style="border: 2px solid #1090C2;; background-color: #1090C2;; color: white;"
                                        class="text-center">
                                        <span>Total</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.expenses_ids" t-as="line">
                                    <tr>
                                        <td class="text-center o_price_total" style="border: 2px solid #1090C2;">
                                            <span t-field="line.name"/>
                                        </td>
                                        <td class="text-center" style="border: 2px solid #1090C2;">
                                            <span t-field="line.quantity"/>
                                        </td>
                                        <td class="text-center" style="border: 2px solid #1090C2;">
                                            <span class="text-nowrap" t-field="line.price_unit"/>
                                        </td>
                                        <td class="text-center o_price_total" style="border: 2px solid #1090C2;">
                                            <span class="text-nowrap" t-field="line.price_subtotal"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <br></br>

                        <table width="45%" style="margin-left: auto;">
                            <tr>
                                <td class="text-center" width="20%" style="border: 2px solid #2DB209;">
                                    <span t-field="o.amount_taxed"/>
                                </td>
                                <td class="text-right" width="20%" style="border: 2px solid #2DB209;">
                                    Total before tax
                                </td>
                            </tr>
                            <tr>
                                <td class="text-center" width="20%" style="border: 2px solid #2DB209;">
                                    <span t-field="o.tax"/>
                                </td>
                                <td class="text-right" width="20%" style="border: 2px solid #2DB209;">
                                    Taxes
                                </td>
                            </tr>
                            <tr>
                                <td class="text-center" width="20%" style="border: 2px solid #2DB209;">
                                    <span t-field="o.total"/>
                                </td>
                                <td class="text-right" width="20%" style="border: 2px solid #2DB209;">
                                    Total
                                </td>
                            </tr>
                        </table>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <div>
                            <span>Prepared By:</span>
                            <span style="margin-left: 270px;">Approved By:</span>
                            <span style="margin-left: 250px;">Received By:</span>
                        </div>

                        <br/>
                        <div>
                            <span style="border: 2px solid #1090C2;color:white">Prepared Prepared By:</span>
                            <span style="margin-left: 180px;border: 2px solid #1090C2;color:white">Approved
                                ApprovedBy:
                            </span>
                            <span style="margin-left: 150px;border: 2px solid #1090C2;color:white">Received Approved:
                            </span>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <template id="custom_standard_external_layout"
                  inherit_id="web.external_layout_standard">
            <xpath expr="//img[contains(@t-att-src, 'company.logo')]" position="replace">
                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 100px;" alt="Logo"/>
            </xpath>
        </template>
    </data>
</odoo>