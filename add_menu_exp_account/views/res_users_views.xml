<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Inherit Form View to Modify it -->
    <record id="department_view_users_form" model="ir.ui.view">
        <field name="name">department.view.users.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Expense Department">
                    <group>
                        <group>
                            <field name="department_id"/>
                        </group>
                        <group></group>
                    </group>
                </page>
                <page string="Expense Manager">
                    <group>
                        <group string="Expense Manager">
                            <field name="direct_manager"/>
                            <field name="administration_management"/>
                            <field name="account1"/>
                            <field name="chief_acc"/>
                            <field name="cfo"/>
                            <field name="upload_bank"/>
                            <field name="approve"/>
                            <field name="account2"/>
                        </group>
                        <group string="Financial Expense Manager">
                            <field name="financial_chief_acc"/>
                            <field name="financial_cfo"/>
                            <field name="financial_upload_bank"/>
                            <field name="financial_approve"/>
                            <field name="financial_account2"/>


                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>