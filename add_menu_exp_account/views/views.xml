<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="expense_view_form" model="ir.ui.view">
            <field name="name">expense_view_form</field>
            <field name="model">expense.expense</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                        <button name="to_direct_manager" string="To Direct Manager"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'draft'"
                                groups="add_menu_exp_account.group_creator"/>
                        <button name="to_account1" string="To Account 1"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'direct_manager'"
                                groups="add_menu_exp_account.group_direct_manager"/>

                        <button name="to_account_manager" string="To Account Manager"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'account1'"
                                groups="add_menu_exp_account.group_account1"/>

                        <button name="to_financial_manager" string="To Financial Manager"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'account_manager'"
                                groups="add_menu_exp_account.group_account_manager"/>

                        <button name="to_cash_management" string="To Cash Management"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'financial_manager'"
                                groups="add_menu_exp_account.group_financial_manager"/>

                        <button name="to_account2" string="To Account 2"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'cash_management'"
                                groups="add_menu_exp_account.group_cash_management"/>


                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="seq" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="expense_date"
                                       readonly="state == 'confirm'"/>
                                <field name="user_id" invisible="0" readonly="1"/>
                                <field name="department_id" invisible="0" readonly="1"/>
                            </group>
                            <group>
                                <!--                                <field name="journal_id"-->
                                <!--                                       readonly="state == 'confirm'"/>-->
                                <!--                                <field name="journal_entry_id" readonly="1"-->
                                <!--                                />-->
                                <field name="company_id" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Expenses">
                                <field name="expenses_ids"
                                       readonly="state == 'confirm'">
                                    <list editable="bottom">
                                        <field name="product_ids" options="{'no_create': True}"/>
                                        <field name="name" optional="show"/>
                                        <field name="account_id" optional="show"/>
                                        <field name="vendor_id" optional="show"/>
                                        <field name="attachment_ids" widget="many2many_binary" optional="show"
                                               readonly="parent.state not in ['draft', 'financial_manager']"/>
                                        <field name="quantity" optional="show"/>
                                        <field name="price_unit" optional="show"/>
                                        <field name="tax_ids" widget="many2many_tags" optional="show"/>
                                        <field name="vat_value" column_invisible="1"/>
                                        <field name="price_subtotal" optional="show"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Assign to Users">
                                <group>
                                    <group>
                                        <field name="direct_manager" options="{'no_create': True}"
                                               required="state == 'draft'" readonly="state != 'draft'"/>
                                        <field name="account1" options="{'no_create': True}"
                                               required="state == 'direct_manager'"
                                               readonly="state != 'direct_manager'"/>
                                        <field name="account_manager" options="{'no_create': True}"
                                               required="state == 'account1'" readonly="state != 'account1'"/>
                                    </group>
                                    <group>
                                        <field name="financial_manager" options="{'no_create': True}" required="state == 'account_manager'" readonly="state != 'account_manager'"/>
                                        <field name="cash_management" options="{'no_create': True}" required="state == 'financial_manager'" readonly="state != 'financial_manager'"/>
                                        <field name="account2" options="{'no_create': True}" required="state == 'cash_management'" readonly="state != 'cash_management'"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <group>
                            <group>

                            </group>
                            <group class="oe_subtotal_footer oe_right" colspan="2">
                                <field name="amount_taxed" widget="monetary" readonly="1"/>
                                <field name="tax" widget="monetary" readonly="1"/>
                                <field name="total" widget="monetary" readonly="1"/>
                            </group>
                        </group>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="expense_view_tree" model="ir.ui.view">
            <field name="name">expense_view_tree</field>
            <field name="model">expense.expense</field>
            <field name="arch" type="xml">
                <list string="">
                    <field name="seq" readonly="1"/>
                    <field name="name"/>
                    <field name="expense_date"/>
                    <!--                    <field name="journal_id"/>-->
                    <field name="total" sum="Total"/>
                    <field name="amount_taxed" sum="Un Taxed"/>
                    <field name="tax" sum="Tax"/>
                </list>
            </field>
        </record>


        <record id="Expense_view_action" model="ir.actions.act_window">
            <field name="name">Expenses</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">expense.expense</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
            </field>
        </record>


        <!--        <menuitem id="Expense_view_menu_ID_categ" name="Expenses" parent="account.menu_finance" sequence="34"/>-->
        <menuitem id="Expense_view_menu_ID_categ" name="Expenses"
                  web_icon="add_menu_exp_account,static/description/icon.png"/>
        <menuitem id="Expense_view_menu" name="Expenses" parent="add_menu_exp_account.Expense_view_menu_ID_categ"
                  action="Expense_view_action" sequence="2"/>


    </data>
</odoo>