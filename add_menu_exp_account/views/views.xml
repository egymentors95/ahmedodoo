<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="expense_view_form" model="ir.ui.view">
            <field name="name">expense_view_form</field>
            <field name="model">expense.expense</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                        <button name="to_direct_manager" string="To Direct Manager"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'draft'"
                                groups="add_menu_exp_account.group_creator,add_menu_exp_account.group_expense_adminstrator"/>

                        <button name="to_administration_management" string="To Administration Management"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'direct_manager'"
                                groups="add_menu_exp_account.group_direct_manager,add_menu_exp_account.group_expense_adminstrator"/>

                        <button name="to_chief_acc" string="To Chief Accountant"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'administration_management'"
                                groups="add_menu_exp_account.group_administration_management,add_menu_exp_account.group_expense_adminstrator"/>

                        <button name="to_cfo" string="To CFO"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'chief_acc'"
                                groups="add_menu_exp_account.group_chief_acc,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="to_upload_bank" string="To Upload Bank"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'cfo'"
                                groups="add_menu_exp_account.group_cfo,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="to_approve" string="To Approve"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'upload_bank'"
                                groups="add_menu_exp_account.group_upload_bank,add_menu_exp_account.group_expense_adminstrator"/>

                        <button name="to_account2" string="To Account 2"
                                class="oe_highlight"
                                type="object"
                                invisible="state != 'approve'"
                                groups="add_menu_exp_account.group_approve,add_menu_exp_account.group_expense_adminstrator"/>
                        <!--                             Refuse                                -->
                        <button name="refuse_direct_manager" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'direct_manager'"
                                groups="add_menu_exp_account.group_direct_manager,add_menu_exp_account.group_expense_adminstrator"/>

                        <button name="refuse_administration_management" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'administration_management'"
                                groups="add_menu_exp_account.group_administration_management,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="refuse_chief_acc" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'chief_acc'"
                                groups="add_menu_exp_account.group_chief_acc,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="refuse_cfo" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'cfo'"
                                groups="add_menu_exp_account.group_cfo,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="refuse_upload_bank" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'upload_bank'"
                                groups="add_menu_exp_account.group_upload_bank,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="refuse_approve" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'approve'"
                                groups="add_menu_exp_account.group_approve,add_menu_exp_account.group_expense_adminstrator"/>
                        <button name="refuse_account2" string="Refuse"
                                class="btn-danger"
                                type="object"
                                invisible="state != 'account2'"
                                groups="add_menu_exp_account.group_expense_adminstrator"/>


                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="seq" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="expense_date"
                                       readonly="state != 'draft'"/>
                                <field name="user_id" invisible="0" readonly="1"/>
                                <field name="department_id" invisible="0" readonly="1"/>
                            </group>
                            <group>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
                            </group>
                            <group>
                                <field name="name" readonly="state != 'draft'"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Expenses">
                                <field name="expenses_ids"
                                       readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="product_ids" options="{'no_create': True}"/>
                                        <field name="name" optional="show"/>
                                        <field name="vendor_id" optional="show"/>
                                        <field name="attachment_ids" widget="many2many_binary" optional="show"
                                               readonly="parent.state not in ['draft', 'financial_manager']"/>
                                        <field name="quantity" optional="show"/>
                                        <field name="price_unit" optional="show"/>
                                        <field name="tax_ids" widget="many2many_tags" optional="show"/>
                                        <field name="vat_value" optional="show"/>
                                        <field name="price_subtotal" optional="show"/>
                                    </list>
                                </field>
                                <group>
                                    <group>

                                    </group>
                                    <group class="oe_subtotal_footer oe_right" colspan="2">
                                        <field name="amount_taxed" widget="monetary" readonly="1"/>
                                        <field name="tax" widget="monetary" readonly="1"/>
                                        <field name="total" widget="monetary" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Assign to Users" invisible="1">
                                <group>
                                    <group>
                                        <field name="direct_manager" options="{'no_create': True}"/>
y                                        <field name="administration_management" options="{'no_create': True}"/>
                                        <field name="chief_acc" options="{'no_create': True}"/>
                                    </group>
                                    <group>
                                        <field name="cfo" options="{'no_create': True}"/>
                                        <field name="upload_bank" options="{'no_create': True}"/>
                                        <field name="approve" options="{'no_create': True}"/>
                                        <field name="account2" options="{'no_create': True}"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="expense_view_tree" model="ir.ui.view">
            <field name="name">expense_view_tree</field>
            <field name="model">expense.expense</field>
            <field name="arch" type="xml">
                <list string="">
                    <field name="seq" readonly="1"/>
                    <field name="user_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                    <field name="expense_date"/>
                    <field name="total" sum="Total"/>
                    <field name="amount_taxed" sum="Un Taxed"/>
                    <field name="tax" sum="Tax"/>
                </list>
            </field>
        </record>


        <record id="Expense_view_action" model="ir.actions.act_window">
            <field name="name">Expenses</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">expense.expense</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
            </field>
        </record>


        <!--        <menuitem id="Expense_view_menu_ID_categ" name="Expenses" parent="account.menu_finance" sequence="34"/>-->
        <menuitem id="Expense_view_menu_ID_categ" name="Expenses"
                  web_icon="add_menu_exp_account,static/description/icon.png" groups="add_menu_exp_account.group_expense_user"/>

        <menuitem id="expense_category_view" name="Expenses" parent="add_menu_exp_account.Expense_view_menu_ID_categ" sequence="10"/>
        <menuitem id="Expense_view_menu" name="Expenses" parent="add_menu_exp_account.expense_category_view"
                  action="Expense_view_action" sequence="10"/>


    </data>
</odoo>