<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_expense" model="ir.module.category">
            <field name="name">Expenses</field>
            <field name="sequence">25</field>
        </record>
        <record model="res.groups.privilege" id="expense_privilege_user">
            <field name="name">Expenses</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>


        <record id="group_expense_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">1</field>
            <field name="privilege_id" ref="expense_privilege_user"/>
        </record>

        <record id="group_expense_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">2</field>
            <field name="privilege_id" ref="expense_privilege_user"/>
            <field name="implied_ids" eval="[(4, ref('add_menu_exp_account.group_expense_user'))]"/>
        </record>


        <record id="expense_expense_company_rule" model="ir.rule">
            <field name="name">expense expense Multi-Company</field>
            <field name="model_id" ref="model_expense_expense"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>
        <record id="expense_line_company_rule" model="ir.rule">
            <field name="name">expense line Multi-Company</field>
            <field name="model_id" ref="model_expense_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>


        <record id="expense_rule_user_own_only" model="ir.rule">
            <field name="name">Expense: User sees only his expenses</field>
            <field name="model_id" ref="model_expense_expense"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                [
                ('user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_expense_user'))]"/>
        </record>

        <record id="expense_line_rule_user_own_only" model="ir.rule">
            <field name="name">Expense Line: User sees only his lines</field>
            <field name="model_id" ref="model_expense_line"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                [
                ('invoice_id.user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_expense_user'))]"/>
        </record>


        <record id="expense_rule_manager_all" model="ir.rule">
            <field name="name">Expense: Manager sees all</field>
            <field name="model_id" ref="model_expense_expense"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_expense_manager'))]"/>
        </record>
        <record id="expense_line_rule_manager_all" model="ir.rule">
            <field name="name">Expense Line: Manager sees all</field>
            <field name="model_id" ref="model_expense_line"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_expense_manager'))]"/>
        </record>
         <record id="attachment_rule_manager_all" model="ir.rule">
            <field name="name">Attachments: Manager sees all</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_expense_manager'))]"/>
        </record>


        <!--        _______________________________Buttons Groups_______________________________    -->


        <record id="expense_privilege_creator" model="res.groups.privilege">
            <field name="name">Creator</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_direct_manager" model="res.groups.privilege">
            <field name="name">Direct Manager</field>
            <field name="sequence">110</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_account1" model="res.groups.privilege">
            <field name="name">Account 1</field>
            <field name="sequence">120</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_account_manager" model="res.groups.privilege">
            <field name="name">Account Manager</field>
            <field name="sequence">130</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_financial_manager" model="res.groups.privilege">
            <field name="name">Financial Manager</field>
            <field name="sequence">140</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_cash_management" model="res.groups.privilege">
            <field name="name">Cash Management</field>
            <field name="sequence">150</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <record id="expense_privilege_account2" model="res.groups.privilege">
            <field name="name">Account 2</field>
            <field name="sequence">160</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_expense"/>
        </record>
        <!--_____________groups for buttons_______________________________    &ndash;&gt;-->
        <record id="group_creator" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_creator"/>
        </record>

        <record id="group_direct_manager" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_direct_manager"/>

        </record>

        <record id="group_account1" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_account1"/>

        </record>

        <record id="group_account_manager" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_account_manager"/>

        </record>

        <record id="group_financial_manager" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_financial_manager"/>
        </record>

        <record id="group_cash_management" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_cash_management"/>
        </record>

        <record id="group_account2" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="expense_privilege_account2"/>
        </record>


    </data>
</odoo>