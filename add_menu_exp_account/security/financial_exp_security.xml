<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--                                    Category                                -->
        <record id="module_category_financial_expense" model="ir.module.category">
            <field name="name">Financial Expenses</field>
            <field name="sequence">30</field>
        </record>
        <!--                                    Privilege                                -->

        <record model="res.groups.privilege" id="financial_expense_privilege_admin">
            <field name="name">Administrator</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>

        <record model="res.groups.privilege" id="financial_expense_privilege_user">
            <field name="name">Financial Expenses</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>

        <record id="financial_expense_privilege_creator" model="res.groups.privilege">
            <field name="name">Creator</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>
        <record id="financial_expense_privilege_account1" model="res.groups.privilege">
            <field name="name">Account 1</field>
            <field name="sequence">110</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>

        <record id="financial_expense_privilege_chief_acc" model="res.groups.privilege">
            <field name="name">Chief Acc</field>
            <field name="sequence">120</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>
        <record id="financial_expense_privilege_cfo" model="res.groups.privilege">
            <field name="name">CFO</field>
            <field name="sequence">130</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>
        <record id="financial_expense_privilege_upload_bank" model="res.groups.privilege">
            <field name="name">Upload Bank</field>
            <field name="sequence">140</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>
        <record id="financial_expense_privilege_approve" model="res.groups.privilege">
            <field name="name">Approve</field>
            <field name="sequence">150</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>
        <record id="financial_expense_privilege_account2" model="res.groups.privilege">
            <field name="name">Account 2</field>
            <field name="sequence">160</field>
            <field name="category_id" ref="add_menu_exp_account.module_category_financial_expense"/>
        </record>

        <!--                                    Groups                                -->

        <record id="group_financial_expense_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="sequence">1</field>
            <field name="privilege_id" ref="financial_expense_privilege_admin"/>
        </record>

        <record id="group_financial_expense_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">1</field>
            <field name="privilege_id" ref="financial_expense_privilege_user"/>
        </record>

        <record id="group_financial_expense_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">2</field>
            <field name="privilege_id" ref="financial_expense_privilege_user"/>
            <field name="implied_ids" eval="[(4, ref('add_menu_exp_account.group_financial_expense_user'))]"/>
        </record>


        <record id="group_financial_creator" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_creator"/>
        </record>

        <record id="group_financial_account1" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_account1"/>

        </record>

        <record id="group_financial_chief_acc" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_chief_acc"/>
        </record>

        <record id="group_financial_cfo" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_cfo"/>
        </record>

        <record id="group_financial_upload_bank" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_upload_bank"/>
        </record>

        <record id="group_financial_approve" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_approve"/>
        </record>

        <record id="group_financial_account2" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="financial_expense_privilege_account2"/>
        </record>


        <!--                                    Rules                                -->
        <!--                                 Comapny  Rules                                -->
        <record id="financial_expense_company_rule" model="ir.rule">
            <field name="name">Financial Expense: Multi-Company</field>
            <field name="model_id" ref="model_financial_expense"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>
        <record id="financial_expense_line_company_rule" model="ir.rule">
            <field name="name">Financial Expense Line: Multi-Company</field>
            <field name="model_id" ref="model_financial_expense_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>
        <!--                                 Users  Rules                                -->
        <record id="financial_expense_rule_user_own_only" model="ir.rule">
            <field name="name">Financial Expense: User sees only his expenses</field>
            <field name="model_id" ref="model_financial_expense"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                [
                ('user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_financial_expense_user'))]"/>
        </record>

        <record id="financial_expense_line_rule_user_own_only" model="ir.rule">
            <field name="name">Financial Expense Line: User sees only his lines</field>
            <field name="model_id" ref="model_financial_expense_line"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                [
                ('invoice_id.user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_financial_expense_user'))]"/>
        </record>


        <record id="financial_expense_rule_manager_all" model="ir.rule">
            <field name="name">Expense: Manager sees all</field>
            <field name="model_id" ref="model_financial_expense"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_financial_expense_manager'))]"/>
        </record>
        <record id="financial_expense_line_rule_manager_all" model="ir.rule">
            <field name="name">Financial Expense Line: Manager sees all</field>
            <field name="model_id" ref="model_financial_expense_line"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('add_menu_exp_account.group_financial_expense_manager'))]"/>
        </record>


    </data>
</odoo>