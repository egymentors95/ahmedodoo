        <!--        ________________________________________Category_______________________________    -->

          <record id="category_main_apps" model="ir.module.category">
            <field name="name">Main Apps</field>
            <field name="sequence">50</field>
        </record>

        <!--        ________________________________________Contacts_______________________________    -->

        <record model="res.groups.privilege" id="contacts_privilege_user">
